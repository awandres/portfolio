---
import Layout from "../layouts/Layout.astro";

// Base URL for GitHub Pages deployment
const base = import.meta.env.BASE_URL;

// Configuration flags
const SHOW_AI_CONTENT = false; // Set to true to show AI-related badges, filters, and descriptions
const DEFAULT_FEATURED_PROJECT = "arcprocure"; // Project ID to show as default featured

// Type for project stack
type ProjectStack = Record<string, string[]>;

interface Project {
  id: string;
  title: string;
  description: string;
  stack: ProjectStack;
  gradient: string;
  badge: string;
  link: string;
  image?: string;
  images?: string[]; // Support for multiple images
  imageContain?: boolean; // Use object-fit: contain with white background
  github?: string;
  live?: string;
  liveLabel?: string; // Custom label for live link (e.g., "Company Site")
  demoLinks?: { label: string; url: string; note?: string }[]; // Multiple demo links
}

// Define projects with their categorized technology stacks
const allProjects: Project[] = [
  {
    id: "arcprocure",
    title: "Arc Procure",
    description:
      "Custom government procurement software built under contract with A-Frame Solutions. Streamlines contract solicitation and vendor proposal processes with dynamic form builders, CLIN pricing structures, and multi-phase submission workflows.",
    stack: {
      Frontend: ["Next.js", "React", "TypeScript"],
      Backend: ["tRPC", "Prisma"],
      Database: ["PostgreSQL"],
    },
    gradient: "linear-gradient(135deg, #1a365d 0%, #2c5282 100%)",
    badge: "Current",
    link: `${base}/projects`,
    live: "https://www.aframesolutions.com/",
    liveLabel: "Company Site",
    demoLinks: [
      { label: "DEMO - Vendor", url: "https://www.arcprocure.com/" },
      { label: "DEMO - Buyer", url: "https://buyer.arcprocure.com/" },
    ],
    images: [
      `${base}/images/arc-propose-clins.png`,
      `${base}/images/arc-propose-submission.png`,
      `${base}/images/arc-propose-compare.png`,
      `${base}/images/arc-propose-clin-compare.png`,
      `${base}/images/arc-propose-buyer.png`,
    ],
  },
  {
    id: "arcinsight",
    title: "Arc Insight",
    description:
      "AI-powered document analysis and editor built under contract with A-Frame Solutions for the IRS. Leverages machine learning to intelligently parse, categorize, and extract key information from complex government documents.",
    stack: {
      Frontend: ["Next.js", "React", "TypeScript"],
      Backend: ["tRPC", "Prisma"],
      Database: ["PostgreSQL"],
      AI: ["Vercel AI SDK"],
    },
    gradient: "linear-gradient(135deg, #2d5016 0%, #4a7c23 100%)",
    badge: "IRS",
    link: `${base}/projects`,
    live: "https://www.aframesolutions.com/",
    liveLabel: "Company Site",
    images: [
      `${base}/images/arc-select-editor.png`,
      `${base}/images/arc-select-chat.png`,
      `${base}/images/arc-procure-demo-example.png`,
    ],
  },
  {
    id: "vettedcrm",
    title: "Personal Trainer CRM",
    description:
      "Full-stack CRM platform with dedicated features for client management, team coordination, and admin dashboards. Includes KPI tracking, prescription builder, session scheduling, and payroll integration. Built with real client data (scrambled for demo).",
    stack: {
      Frontend: ["Next.js", "React", "TypeScript"],
      Backend: ["tRPC", "Prisma"],
      Database: ["PostgreSQL"],
      Cloud: ["Vercel"],
    },
    gradient: "linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)",
    badge: "Live",
    link: `${base}/projects`,
    live: "https://vetted-trainers-app-admin.vercel.app/login",
    images: [
      `${base}/images/vetted-crm-dashboard.png`,
      `${base}/images/vetted-crm-prescriptions.png`,
      `${base}/images/vetted-crm-builder.png`,
      `${base}/images/vetted-crm-video.png`,
    ],
  },
  {
    id: "fedoil",
    title: "Federal Oil Reserve",
    description:
      "Government website for bidding on Federal oil reserves with interactive dashboards. Note: This system is hosted on secure government cloud infrastructure and is not publicly accessible.",
    stack: {
      Frontend: ["Blazor", "Angular"],
      Backend: ["C#", "ASP.NET"],
      Database: ["SQL Server"],
      Cloud: ["Azure Gov"],
    },
    gradient: "linear-gradient(135deg, #2d3748 0%, #4a5568 100%)",
    badge: "DOE",
    link: `${base}/projects`,
    image: `${base}/images/original_doe_logo.png`,
    imageContain: true,
  },
  {
    id: "ihire",
    title: "iHire",
    description:
      "Enterprise job board platform with 14M+ users. Built CRM and notification systems.",
    stack: {
      Frontend: ["Angular", "Vue.js"],
      Backend: ["C#", "ASP.NET"],
      Database: ["SQL Server"],
    },
    gradient: "linear-gradient(135deg, #00c6ff 0%, #0072ff 100%)",
    badge: "Enterprise",
    link: `${base}/projects`,
    images: [
      `${base}/images/ihire-website-image.png`,
      `${base}/images/iHire-Example-Site.png`,
      `${base}/images/ihire-sections.png`,
      `${base}/images/ihire-prescreening.png`,
    ],
    live: "https://www.ihire.com",
  },
  {
    id: "dealeron",
    title: "DealerOn",
    description:
      "Designed and managed automotive dealer websites on a multi-tenant CMS platform serving thousands of dealerships. Created templates, managed OEM data feeds, and designed featured vehicle pages for new models.",
    stack: {
      Frontend: ["Angular", "JavaScript"],
      Backend: ["C#", "ASP.NET"],
      CMS: ["Multi-Tenant"],
    },
    gradient: "linear-gradient(135deg, #ff6b35 0%, #f7931e 100%)",
    badge: "Enterprise",
    link: `${base}/projects`,
    images: [
      `${base}/images/dealeron-cosmos.png`,
      `${base}/images/dealeron-darcars.png`,
      `${base}/images/dealeron-subaru.png`,
      `${base}/images/dealeron-darcars-home.png`,
      `${base}/images/dealeron-darcars-lineup.png`,
    ],
    live: "https://www.darcarstoyotaoffrederick.com/",
    liveLabel: "Example Site",
  },
  {
    id: "soundsgood",
    title: "SoundsGood Software",
    description:
      "An app development hub that creates and ships app templates for a range of business verticals. Full-stack monorepo platform with shared packages and multi-tenant support. Features modern architecture with Turborepo, authentication, and modern tooling.",
    stack: {
      Frontend: ["Next.js", "React", "TypeScript"],
      Backend: ["tRPC", "Better-Auth"],
      Database: ["Drizzle ORM", "PostgreSQL"],
      DevOps: ["Turborepo", "pnpm"],
    },
    gradient: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
    badge: "Live",
    link: `${base}/projects`,
    live: "https://www.soundsgoodapps.com/login",
    images: [
      `${base}/images/soundsgood-apps-demo.png`,
      `${base}/images/soundsgood-project-status.png`,
      `${base}/images/soundsgood-admin.png`,
      `${base}/images/soundsgood-store.png`,
      `${base}/images/soundsgood-pos.png`,
      `${base}/images/soundsgood-musicians.png`,
    ],
  },
  {
    id: "gearcatalog",
    title: "Gear Catalog",
    description:
      "DEMO PROJECT: Professional studio equipment management system featuring gear browsing, project-based loadouts, and image management via Vercel Blob. To explore full functionality, click 'Admin Access' and enter password 'tester123'.",
    stack: {
      Frontend: ["Next.js", "React", "TypeScript"],
      Database: ["Prisma", "PostgreSQL"],
      Cloud: ["Vercel"],
    },
    gradient: "linear-gradient(135deg, #11998e 0%, #38ef7d 100%)",
    badge: "Demo",
    link: `${base}/projects`,
    live: "https://gear-catalogue.vercel.app/gear",
    image: `${base}/images/gear-catalogue-demo.png`,
  },
  {
    id: "milestones",
    title: "The Milestones",
    description:
      "Full band website with Spotify/YouTube embeds, galleries, and contact integration.",
    stack: {
      Frontend: ["HTML5", "CSS3", "JavaScript"],
      Libraries: ["Bootstrap", "jQuery"],
    },
    gradient: "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
    badge: "Live",
    link: `${base}/projects`,
    images: [
      `${base}/images/the-milestones-website-image.png`,
      `${base}/images/mstones.png`,
    ],
    live: "https://themilestones.band",
  },
  {
    id: "vetted",
    title: "Vetted Trainers",
    description:
      "SEO-optimized fitness training website with SSR for Google crawling.",
    stack: {
      Frontend: ["Next.js", "React", "TypeScript"],
    },
    gradient: "linear-gradient(135deg, #f7971e 0%, #ffd200 100%)",
    badge: "Freelance",
    link: `${base}/projects`,
    image: `${base}/images/vetted.png`,
    github: "https://github.com/awandres/vetted-trainers",
  },
  {
    id: "centennial",
    title: "IAAPA Centennial",
    description:
      "Micro-site celebrating IAAPA's 100th anniversary with timeline and admin portal.",
    stack: {
      Frontend: ["AngularJS"],
      Backend: ["Node.js", "Express"],
      Database: ["MongoDB"],
    },
    gradient: "linear-gradient(135deg, #8E2DE2 0%, #4A00E0 100%)",
    badge: "Freelance",
    link: `${base}/projects`,
    image: `${base}/images/centennial.png`,
    github: "https://github.com/awandres/centennial",
  },
  {
    id: "alexcoomerlaw",
    title: "Alex Coomer Law",
    description:
      "Website for bankruptcy law firm with client resources and FAQs.",
    stack: {
      Frontend: ["React"],
      Backend: ["Express"],
    },
    gradient: "linear-gradient(135deg, #1e3c72 0%, #2a5298 100%)",
    badge: "Freelance",
    link: `${base}/projects`,
    image: `${base}/images/alexcoomerlaw.png`,
    github: "https://github.com/awandres/alexcoomerlaw",
    live: "https://awandres.github.io/alexcoomerlaw/#/",
  },
  {
    id: "bigbamboo",
    title: "Big Bamboo",
    description:
      "Bed and breakfast resort website in Costa Rica with rebranding focus.",
    stack: {
      CMS: ["Wordpress"],
    },
    gradient: "linear-gradient(135deg, #56ab2f 0%, #a8e063 100%)",
    badge: "Client Site",
    link: `${base}/projects`,
    image: `${base}/images/bigbamboo_ss.png`,
    live: "http://www.bigbamboouvita.com/",
  },
  {
    id: "debellis",
    title: "Debellis + Ferrara",
    description: "Responsive landing page ads for marketing agency clients.",
    stack: {
      Frontend: ["HTML", "CSS", "Bootstrap", "JavaScript"],
    },
    gradient: "linear-gradient(135deg, #ff6b6b 0%, #feca57 100%)",
    badge: "Agency",
    link: `${base}/projects`,
    image: `${base}/images/debellis-ad.png`,
  },
  {
    id: "tradegrounds",
    title: "Tradegrounds",
    description: "Cross-platform mobile app for local e-commerce vendors.",
    stack: {
      Mobile: ["Flutter", "Dart"],
      Database: ["Cloud Firestore"],
    },
    gradient: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
    badge: "Startup",
    link: `${base}/projects`,
    github: "https://gitlab.com/awandres",
  },
];

// Collect all unique techs from all stacks
const allTechs = [
  ...new Set(allProjects.flatMap((p) => Object.values(p.stack).flat())),
].sort();

// Helper function to get all techs from a stack as a flat array
const getStackTechs = (stack: ProjectStack) => {
  return Object.values(stack).flat();
};
---

<Layout title="Alex Wandres | Full Stack Software Engineer">
  <section class="hero">
    <div class="hero-content">
      <div class="hero-image-container">
        <img
          src={`${base}/images/headshot.jpg`}
          alt="Alex Wandres"
          class="hero-image"
        />
      </div>

      <div class="hero-text">
        <p class="label">Full Stack Software Engineer</p>
        <h1 class="hero-title">Alex Wandres</h1>

        <p class="hero-description">
          I build modern applications with intuitive UX and elegant design. I
          have worked on a wide range of projects, from freelance clients, to
          large event companies, enterprise code shops, and government contracts
          for DOE and NIH.
        </p>

        <div class="hero-highlights">
          <div class="highlight">
            <span class="highlight-number">8+</span>
            <span class="highlight-label">Years Experience</span>
          </div>
          <div class="highlight">
            <span class="highlight-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
            <span class="highlight-label">Public Trust Clearance</span>
          </div>
          <div class="highlight">
            <span class="highlight-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/><path d="M9 9h.01"/><path d="M15 9h.01"/><path d="M9 13h.01"/><path d="M15 13h.01"/></svg></span>
            <span class="highlight-label">Gov Contractor</span>
          </div>
        </div>

        <div class="hero-cta">
          <a href={`${base}/projects`} class="btn btn-primary">View My Work</a>
          <a href={`${base}/contact`} class="btn btn-secondary">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">What I Do</h2>

    <div class="cards-grid">
      <div class="card">
        <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18"/><path d="M5 21V7l7-4 7 4v14"/><path d="M9 21v-6h6v6"/><path d="M9 9h.01"/><path d="M15 9h.01"/><path d="M9 13h.01"/><path d="M15 13h.01"/></svg></div>
        <h3>Government Software</h3>
        <p>
          Building secure, compliant applications for federal agencies including
          NIH and Department of Energy. Public Trust clearance holder.
        </p>
      </div>

      <div class="card featured">
        <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg></div>
        <h3>Rapid Development</h3>
        <p>
          Delivering production-quality software efficiently using modern tooling
          and streamlined workflows.
        </p>
      </div>

      <div class="card">
        <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h3v3H7z"/><path d="M14 7h3"/><path d="M14 11h3"/><path d="M7 14h10"/><path d="M7 18h10"/></svg></div>
        <h3>Full Stack Development</h3>
        <p>
          C#/.NET, React, Angular, Next.js, PostgreSQL, Azure Cloud. End-to-end
          application development and modernization.
        </p>
      </div>

      <div class="card">
        <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
        <h3>Creative Projects</h3>
        <p>
          Personal projects in music and audio tech. Band websites, studio gear
          catalogs, and creative digital solutions.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Skills & Technologies</h2>
    <p class="filter-hint">Click on skills to filter projects below</p>

    <div class="skills-container">
      <div class="skill-group">
        <h3>Frontend</h3>
        <div class="skill-tags">
          <button class="skill-tag" data-tech="React">React</button>
          <button class="skill-tag" data-tech="Next.js">Next.js</button>
          <button class="skill-tag" data-tech="Angular">Angular</button>
          <button class="skill-tag" data-tech="AngularJS">AngularJS</button>
          <button class="skill-tag" data-tech="Vue.js">Vue.js</button>
          <button class="skill-tag" data-tech="Blazor">Blazor</button>
          <button class="skill-tag" data-tech="jQuery">jQuery</button>
          <button class="skill-tag" data-tech="TypeScript">TypeScript</button>
          <button class="skill-tag" data-tech="HTML5">HTML5</button>
          <button class="skill-tag" data-tech="CSS3">CSS3</button>
        </div>
      </div>

      <div class="skill-group">
        <h3>Backend</h3>
        <div class="skill-tags">
          <button class="skill-tag" data-tech="C#">C#</button>
          <button class="skill-tag" data-tech="ASP.NET">ASP.NET</button>
          <button class="skill-tag" data-tech="Node.js">Node.js</button>
          <button class="skill-tag" data-tech="Express">Express</button>
          <button class="skill-tag" data-tech="SQL Server">SQL Server</button>
          <button class="skill-tag" data-tech="PostgreSQL">PostgreSQL</button>
          <button class="skill-tag" data-tech="MongoDB">MongoDB</button>
          <button class="skill-tag" data-tech="Prisma">Prisma</button>
          <button class="skill-tag" data-tech="Drizzle ORM">Drizzle ORM</button>
        </div>
      </div>

      <div class="skill-group">
        <h3>Cloud & DevOps</h3>
        <div class="skill-tags">
          <button class="skill-tag" data-tech="Azure">Azure</button>
          <button class="skill-tag" data-tech="Vercel">Vercel</button>
          <button class="skill-tag" data-tech="Cloud Firestore"
            >Cloud Firestore</button
          >
        </div>
      </div>

      {SHOW_AI_CONTENT && (
        <div class="skill-group featured">
          <h3><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline; vertical-align: middle; margin-right: 6px;"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>AI Development</h3>
          <div class="skill-tags">
            <button class="skill-tag highlight-tag" data-tech="Claude Code"
              >Claude Code</button
            >
            <button class="skill-tag" data-tech="Full Stack">Full Stack</button>
          </div>
        </div>
      )}

      <div class="skill-group">
        <h3>Mobile</h3>
        <div class="skill-tags">
          <button class="skill-tag" data-tech="Flutter">Flutter</button>
          <button class="skill-tag" data-tech="Dart">Dart</button>
          <button class="skill-tag" data-tech="Mobile">Mobile</button>
        </div>
      </div>
    </div>

    <div class="filter-controls">
      <button id="clear-filters" class="btn btn-small">Clear Filters</button>
      <span id="filter-status"></span>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Projects</h2>

    <!-- Featured Project Display -->
    <div id="featured-project" class="featured-project" style="display: none;">
      <div class="featured-content">
        <div class="featured-info">
          <span class="featured-badge" id="featured-badge"></span>
          <h3 id="featured-title"></h3>
          <p id="featured-description"></p>
          <div class="featured-stack" id="featured-stack"></div>
          <div class="featured-links" id="featured-links"></div>
        </div>
        <div class="featured-visual">
          <div id="featured-image"></div>
        </div>
      </div>
      <button
        class="close-featured"
        id="close-featured"
        aria-label="Close featured project">✕</button
      >
    </div>

    <!-- Image Modal/Lightbox -->
    <div id="image-modal" class="image-modal">
      <div class="modal-backdrop"></div>
      <div class="modal-content">
        <img id="modal-image" src="" alt="Full size image" />
        <button class="modal-close" id="modal-close" aria-label="Close modal"
          >✕</button
        >
        <button
          class="modal-nav modal-prev"
          id="modal-prev"
          aria-label="Previous image">‹</button
        >
        <button
          class="modal-nav modal-next"
          id="modal-next"
          aria-label="Next image">›</button
        >
      </div>
    </div>

    <div class="projects-grid" id="projects-grid">
      {
        allProjects.map((project) => {
          const allStackTechs = getStackTechs(project.stack);

          return (
            <div
              class="project-card"
              data-techs={allStackTechs.join(",")}
              data-title={project.title}
              data-description={project.description}
              data-badge={project.badge}
              data-gradient={project.gradient}
              data-image={project.image || ""}
              data-images={project.images ? JSON.stringify(project.images) : ""}
              data-stack={JSON.stringify(project.stack)}
              data-github={project.github || ""}
              data-live={project.live || ""}
              data-live-label={project.liveLabel || ""}
              data-demo-links={project.demoLinks ? JSON.stringify(project.demoLinks) : ""}
            >
              <div class="project-card-content">
                {project.image ||
                (project.images && project.images.length > 0) ? (
                  <div
                    class={`project-image project-image-photo ${project.imageContain ? "image-contain" : ""}`}
                  >
                    <img
                      src={project.image || project.images![0]}
                      alt={project.title}
                    />
                    <span class="project-badge">{project.badge}</span>
                  </div>
                ) : (
                  <div
                    class="project-image"
                    style={`background: ${project.gradient}`}
                  >
                    <span class="project-badge">{project.badge}</span>
                  </div>
                )}
                <div class="project-info">
                  <h3>{project.title}</h3>
                  <p>{project.description}</p>
                  <div class="project-stack">
                    {Object.entries(project.stack).map(([category, techs]) => (
                      <div class="stack-category">
                        <span class="category-label">{category}</span>
                        {techs.map((tech) => (
                          <span class="tech-tag">{tech}</span>
                        ))}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
              {(project.github || project.live) && (
                <div class="project-links">
                  {project.github && (
                    <a
                      href={project.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link-btn"
                    >
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                      >
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                      </svg>
                      GitHub
                    </a>
                  )}
                  {project.live && (
                    <a
                      href={project.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link-btn"
                    >
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                        <polyline points="15 3 21 3 21 9" />
                        <line x1="10" y1="14" x2="21" y2="3" />
                      </svg>
                      {project.liveLabel || "Live Site"}
                    </a>
                  )}
                  {project.demoLinks && project.demoLinks.map((demo) => (
                    <a
                      href={demo.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-link-btn demo-link"
                    >
                      {demo.label}
                    </a>
                  ))}
                </div>
              )}
              {project.demoLinks && (
                <p class="demo-note">* Click DEV MODE at bottom of demo sites to enable logins</p>
              )}
            </div>
          );
        })
      }
    </div>

    <div class="section-cta">
      <a href={`${base}/projects`} class="btn btn-outline"
        >View Full Project Details →</a
      >
    </div>
  </section>
</Layout>

<script define:vars={{ DEFAULT_FEATURED_PROJECT }}>
  window.PORTFOLIO_CONFIG = {
    defaultFeaturedProject: DEFAULT_FEATURED_PROJECT
  };
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const skillTags = document.querySelectorAll(".skill-tag");
    const projectCards = document.querySelectorAll(".project-card");
    const clearBtn = document.getElementById("clear-filters");
    const filterStatus = document.getElementById("filter-status");
    const featuredProject = document.getElementById("featured-project");
    const closeFeatured = document.getElementById("close-featured");

    // Modal elements
    const imageModal = document.getElementById("image-modal")!;
    const modalImage = document.getElementById(
      "modal-image"
    ) as HTMLImageElement;
    const modalClose = document.getElementById("modal-close")!;
    const modalPrev = document.getElementById("modal-prev")!;
    const modalNext = document.getElementById("modal-next")!;
    const modalBackdrop = imageModal.querySelector(".modal-backdrop")!;

    let selectedTechs: Set<string> = new Set();
    let currentModalImages: string[] = [];
    let currentModalIndex = 0;

    // Modal functions
    function openModal(images: string[], startIndex: number = 0) {
      currentModalImages = images;
      currentModalIndex = startIndex;
      updateModalImage();
      imageModal.style.display = "flex";
      document.body.style.overflow = "hidden";

      // Show/hide nav buttons based on number of images
      if (images.length <= 1) {
        modalPrev.style.display = "none";
        modalNext.style.display = "none";
      } else {
        modalPrev.style.display = "flex";
        modalNext.style.display = "flex";
      }
    }

    function closeModal() {
      imageModal.style.display = "none";
      document.body.style.overflow = "";
    }

    function updateModalImage() {
      modalImage.src = currentModalImages[currentModalIndex];
    }

    function prevImage() {
      currentModalIndex =
        (currentModalIndex - 1 + currentModalImages.length) %
        currentModalImages.length;
      updateModalImage();
    }

    function nextImage() {
      currentModalIndex = (currentModalIndex + 1) % currentModalImages.length;
      updateModalImage();
    }

    // Modal event listeners
    modalClose.addEventListener("click", closeModal);
    modalBackdrop.addEventListener("click", closeModal);
    modalPrev.addEventListener("click", prevImage);
    modalNext.addEventListener("click", nextImage);

    // Keyboard navigation
    document.addEventListener("keydown", (e) => {
      if (imageModal.style.display === "flex") {
        if (e.key === "Escape") closeModal();
        if (e.key === "ArrowLeft") prevImage();
        if (e.key === "ArrowRight") nextImage();
      }
    });

    // Function to display a featured project
    function displayFeaturedProject(card: Element) {
      const projectData = (card as HTMLElement).dataset;

      // Populate featured section
      document.getElementById("featured-badge")!.textContent =
        projectData.badge || "";
      document.getElementById("featured-title")!.textContent =
        projectData.title || "";
      document.getElementById("featured-description")!.textContent =
        projectData.description || "";

      // Build stack display with inline styles
      const stackContainer = document.getElementById("featured-stack")!;
      stackContainer.innerHTML = "";
      stackContainer.style.cssText = `
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 0.5rem;
      `;

      if (projectData.stack) {
        const stackObj = JSON.parse(projectData.stack);
        Object.entries(stackObj).forEach(([category, techs]) => {
          const categoryDiv = document.createElement("div");
          categoryDiv.style.cssText = `
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            align-items: center;
          `;

          const label = document.createElement("span");
          label.style.cssText = `
            font-family: "Titillium Web", sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            color: #aaaaaa;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            min-width: fit-content;
          `;
          label.textContent = category;
          categoryDiv.appendChild(label);

          (techs as string[]).forEach((tech: string) => {
            const techTag = document.createElement("span");
            techTag.style.cssText = `
              background: rgba(77, 255, 195, 0.1);
              color: #4dffc3;
              padding: 0.35rem 0.8rem;
              border-radius: 6px;
              font-size: 0.9rem;
              font-family: "Titillium Web", sans-serif;
              font-weight: 500;
            `;
            techTag.textContent = tech;
            categoryDiv.appendChild(techTag);
          });

          stackContainer.appendChild(categoryDiv);
        });
      }

      // Build links
      const linksContainer = document.getElementById("featured-links")!;
      linksContainer.innerHTML = "";

      if (projectData.github || projectData.live || projectData.demoLinks) {
        if (projectData.github) {
          const githubLink = document.createElement("a");
          githubLink.href = projectData.github;
          githubLink.target = "_blank";
          githubLink.rel = "noopener noreferrer";
          githubLink.className = "project-link-btn";
          githubLink.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" /></svg> GitHub`;
          linksContainer.appendChild(githubLink);
        }

        if (projectData.live) {
          const liveLink = document.createElement("a");
          liveLink.href = projectData.live;
          liveLink.target = "_blank";
          liveLink.rel = "noopener noreferrer";
          liveLink.className = "project-link-btn";
          const liveLabel = projectData.liveLabel || "Live Site";
          liveLink.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg> ${liveLabel}`;
          linksContainer.appendChild(liveLink);
        }

        // Add demo links if available
        if (projectData.demoLinks && projectData.demoLinks !== "") {
          const demoLinks = JSON.parse(projectData.demoLinks);
          demoLinks.forEach((demo: { label: string; url: string }) => {
            const demoLink = document.createElement("a");
            demoLink.href = demo.url;
            demoLink.target = "_blank";
            demoLink.rel = "noopener noreferrer";
            demoLink.className = "project-link-btn demo-link";
            demoLink.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3" /></svg> ${demo.label}`;
            linksContainer.appendChild(demoLink);
          });

          // Add demo note
          const demoNote = document.createElement("p");
          demoNote.className = "demo-note";
          demoNote.style.cssText = "width: 100%; margin-top: 0.5rem; font-size: 0.7rem; color: #777; font-style: italic;";
          demoNote.textContent = "* Click DEV MODE at bottom of demo sites to enable logins and autofill";
          linksContainer.appendChild(demoNote);
        }
      }

      // Build image/gradient with gallery support
      const imageContainer = document.getElementById("featured-image")!;
      imageContainer.innerHTML = "";
      imageContainer.style.width = "100%";

      // Check if project has multiple images
      const hasMultipleImages = projectData.images && projectData.images !== "";
      let imagesToShow: string[] = [];

      if (hasMultipleImages) {
        imagesToShow = JSON.parse(projectData.images!);
      } else if (projectData.image) {
        imagesToShow = [projectData.image];
      }

      if (imagesToShow.length > 0) {
        // Create gallery container with inline styles
        const galleryContainer = document.createElement("div");
        galleryContainer.style.cssText = `
          width: 100%;
          display: flex;
          flex-direction: column;
          gap: 1rem;
        `;

        // Create main image display with inline styles
        const visualDiv = document.createElement("div");
        visualDiv.style.cssText = `
          width: 100%;
          height: 280px;
          border-radius: 12px;
          display: flex;
          align-items: flex-start;
          justify-content: flex-end;
          padding: 1rem;
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
          position: relative;
          overflow: hidden;
          background: #3a3a3a;
          cursor: pointer;
          transition: transform 0.2s ease, box-shadow 0.2s ease;
        `;

        // Add hover effect for main image
        visualDiv.addEventListener("mouseenter", () => {
          visualDiv.style.transform = "scale(1.02)";
          visualDiv.style.boxShadow = "0 12px 32px rgba(77, 255, 195, 0.2)";
        });
        visualDiv.addEventListener("mouseleave", () => {
          visualDiv.style.transform = "scale(1)";
          visualDiv.style.boxShadow = "0 8px 24px rgba(0, 0, 0, 0.4)";
        });

        // Store images for modal access
        const galleryImages = [...imagesToShow];
        let currentImageIndex = 0;

        // Click to open modal
        visualDiv.addEventListener("click", () => {
          openModal(galleryImages, currentImageIndex);
        });

        const img = document.createElement("img");
        img.src = imagesToShow[0];
        img.alt = projectData.title || "";
        img.style.cssText = `
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
        `;
        visualDiv.appendChild(img);

        const badge = document.createElement("span");
        badge.className = "project-badge";
        badge.textContent = projectData.badge || "";
        visualDiv.appendChild(badge);

        galleryContainer.appendChild(visualDiv);

        // Create thumbnails if multiple images
        if (imagesToShow.length > 1) {
          const thumbnailsContainer = document.createElement("div");
          thumbnailsContainer.style.cssText = `
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.75rem;
            padding: 0;
            width: 100%;
          `;

          imagesToShow.forEach((imgSrc, index) => {
            const thumbnail = document.createElement("div");
            const isActive = index === 0;
            thumbnail.style.cssText = `
              width: 100%;
              aspect-ratio: 16/10;
              border-radius: 8px;
              background-size: cover;
              background-position: center;
              cursor: pointer;
              border: 2px solid ${isActive ? "#4dffc3" : "#444444"};
              transition: all 0.2s ease;
              opacity: ${isActive ? "1" : "0.6"};
              background-color: #3a3a3a;
              background-image: url('${imgSrc}');
              ${isActive ? "box-shadow: 0 0 0 3px rgba(77, 255, 195, 0.2);" : ""}
            `;
            thumbnail.setAttribute("data-image-src", imgSrc);

            // Hover effects
            thumbnail.addEventListener("mouseenter", () => {
              if (!thumbnail.classList.contains("active")) {
                thumbnail.style.opacity = "0.9";
                thumbnail.style.borderColor = "#4dffc3";
                thumbnail.style.transform = "translateY(-2px)";
              }
            });
            thumbnail.addEventListener("mouseleave", () => {
              if (!thumbnail.classList.contains("active")) {
                thumbnail.style.opacity = "0.6";
                thumbnail.style.borderColor = "#444444";
                thumbnail.style.transform = "translateY(0)";
              }
            });

            thumbnail.addEventListener("click", () => {
              // Update main image
              img.src = imgSrc;

              // Update current image index for modal
              currentImageIndex = index;

              // Update all thumbnails styling
              thumbnailsContainer.querySelectorAll("div").forEach((t) => {
                t.classList.remove("active");
                (t as HTMLElement).style.opacity = "0.6";
                (t as HTMLElement).style.borderColor = "#444444";
                (t as HTMLElement).style.boxShadow = "none";
                (t as HTMLElement).style.transform = "translateY(0)";
              });

              // Set active thumbnail styling
              thumbnail.classList.add("active");
              thumbnail.style.opacity = "1";
              thumbnail.style.borderColor = "#4dffc3";
              thumbnail.style.boxShadow = "0 0 0 3px rgba(77, 255, 195, 0.2)";
            });

            if (isActive) {
              thumbnail.classList.add("active");
            }

            thumbnailsContainer.appendChild(thumbnail);
          });

          galleryContainer.appendChild(thumbnailsContainer);
        }

        imageContainer.appendChild(galleryContainer);
      } else {
        // Show gradient background with inline styles
        const visualDiv = document.createElement("div");
        visualDiv.style.cssText = `
          width: 100%;
          height: 280px;
          border-radius: 12px;
          display: flex;
          align-items: flex-start;
          justify-content: flex-end;
          padding: 1rem;
          box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
          position: relative;
          overflow: hidden;
          background: ${projectData.gradient || "#3a3a3a"};
        `;

        const badge = document.createElement("span");
        badge.className = "project-badge";
        badge.textContent = projectData.badge || "";
        visualDiv.appendChild(badge);

        imageContainer.appendChild(visualDiv);
      }

      // Show featured section
      featuredProject!.style.display = "block";
    }

    // Set default featured project based on config
    const config = (window as any).PORTFOLIO_CONFIG || {};
    const defaultProjectId = config.defaultFeaturedProject || "arcprocure";
    const defaultCard = Array.from(projectCards).find((card) => {
      return (card as HTMLElement).dataset.id === defaultProjectId;
    });

    if (defaultCard) {
      displayFeaturedProject(defaultCard);
    }

    function updateProjects() {
      let visibleCount = 0;

      // Hide featured project when filters change
      featuredProject!.style.display = "none";

      projectCards.forEach((card) => {
        const cardTechs = (card as HTMLElement).dataset.techs?.split(",") || [];

        if (selectedTechs.size === 0) {
          // No filters - show all
          (card as HTMLElement).style.display = "";
          visibleCount++;
        } else {
          // Check if any selected tech matches this project
          const hasMatch = [...selectedTechs].some((tech) =>
            cardTechs.includes(tech)
          );
          (card as HTMLElement).style.display = hasMatch ? "" : "none";
          if (hasMatch) visibleCount++;
        }
      });

      // Update filter status
      if (selectedTechs.size > 0) {
        filterStatus!.textContent = `Showing ${visibleCount} project${visibleCount !== 1 ? "s" : ""} with: ${[...selectedTechs].join(", ")}`;
      } else {
        filterStatus!.textContent = "";
      }
    }

    // Featured project functionality - add click handlers
    projectCards.forEach((card) => {
      card.addEventListener("click", (e) => {
        // Don't trigger if clicking on links
        if ((e.target as HTMLElement).closest('a[href^="http"]')) {
          return;
        }

        e.preventDefault();
        displayFeaturedProject(card);

        // Scroll to featured section
        featuredProject!.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
        });
      });
    });

    closeFeatured?.addEventListener("click", () => {
      featuredProject!.style.display = "none";
    });

    skillTags.forEach((tag) => {
      tag.addEventListener("click", () => {
        const tech = (tag as HTMLElement).dataset.tech;
        if (!tech) return;

        if (selectedTechs.has(tech)) {
          selectedTechs.delete(tech);
          tag.classList.remove("active");
        } else {
          selectedTechs.add(tech);
          tag.classList.add("active");
        }

        updateProjects();
      });
    });

    clearBtn?.addEventListener("click", () => {
      selectedTechs.clear();
      skillTags.forEach((tag) => tag.classList.remove("active"));
      updateProjects();
    });
  });
</script>

