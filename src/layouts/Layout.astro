---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alex Wandres | Full Stack Developer",
  description = "Full Stack Developer specializing in modern web applications, AI-assisted development, and creative digital solutions.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Titillium+Web:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600;1,700&family=Open+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a
          href={`${base}/`}
          class:list={[
            "nav-link",
            "hvr-fade",
            { active: currentPath === `${base}/` || currentPath === "/" },
          ]}>About Me</a
        >
        <a
          href={`${base}/projects`}
          class:list={[
            "nav-link",
            "hvr-fade",
            {
              active:
                currentPath === `${base}/projects` ||
                currentPath === `${base}/projects/` ||
                currentPath === "/projects" ||
                currentPath === "/projects/",
            },
          ]}>Projects</a
        >
        <a
          href={`${base}/resume`}
          class:list={[
            "nav-link",
            "hvr-fade",
            {
              active:
                currentPath === `${base}/resume` ||
                currentPath === `${base}/resume/` ||
                currentPath === "/resume" ||
                currentPath === "/resume/",
            },
          ]}>Resume</a
        >
        <a
          href={`${base}/contact`}
          class:list={[
            "nav-link",
            "hvr-fade",
            {
              active:
                currentPath === `${base}/contact` ||
                currentPath === `${base}/contact/` ||
                currentPath === "/contact" ||
                currentPath === "/contact/",
            },
          ]}>Contact</a
        >
      </div>
    </nav>
    <hr class="nav-hr" />

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-content">
        <div class="footer-info">
          <p class="footer-name">Alex Wandres</p>
          <p class="footer-tagline">Full Stack Software Engineer</p>
        </div>
        <div class="footer-links">
          <a
            href="https://github.com/awandres"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/alexwandres/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
          </a>
          <a href="mailto:alex.r.wandres@gmail.com" class="footer-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"
              ></path>
            </svg>
          </a>
        </div>
        <p class="footer-copyright">
          © 2024 Alex Wandres. All rights reserved.
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg-primary: #333333;
    --bg-secondary: #3a3a3a;
    --bg-card: #3d3d3d;
    --text-primary: #ffffff;
    --text-secondary: #cccccc;
    --accent: #4dffc3;
    --accent-dim: rgba(77, 255, 195, 0.15);
    --accent-hover: #3de0aa;
    --border-color: #ffffff;
    --font-heading: "Titillium Web", sans-serif;
    --font-body: "Open Sans", sans-serif;
  }

  html {
    font-family: var(--font-body);
    font-weight: 300;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    line-height: 1.6;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:visited,
  a:active,
  a:focus {
    color: #ffffff !important;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.1;
  }

  p {
    color: white;
    font-size: 22px;
  }

  /* Fade hover effect from original */
  .hvr-fade {
    display: inline-block;
    border-radius: 8px;
    vertical-align: middle;
    transform: perspective(1px) translateZ(0);
    box-shadow: 0 0 1px transparent;
    overflow: hidden;
    transition:
      background-color 0.3s ease,
      color 0.8s ease;
  }

  .hvr-fade:hover,
  .hvr-fade:focus,
  .hvr-fade:active {
    background-color: var(--accent);
    border-radius: 8px;
    color: #111111 !important;
    transition:
      background-color 0.3s ease,
      color 0.1s ease;
  }

  /* Animations from original */
  @keyframes fadeIn {
    0% {
      opacity: 0;
    }
    80% {
      opacity: 1;
    }
    100% {
      opacity: 1;
    }
  }

  .fade-in {
    animation: fadeIn 1.5s ease-out;
  }
</style>

<style>
  .nav {
    display: flex;
    justify-content: space-around;
    margin-top: 20px;
    color: #ffffff;
  }

  .nav-inner {
    display: flex;
    justify-content: space-around;
    width: 100%;
    max-width: 800px;
  }

  .nav-link {
    color: #fff;
    padding: 20px;
    font-size: 1rem;
  }

  .nav-link:hover {
    color: black;
  }

  .nav-link.active {
    background-color: var(--accent);
    color: #111111 !important;
    border-radius: 8px;
  }

  .nav-hr {
    width: 80%;
    margin: 20px auto;
    border: none;
    border-top: 1px solid #666;
  }

  @media (max-width: 767px) {
    .nav-link {
      font-size: 14px !important;
      padding: 10px;
    }
  }

  @media (max-width: 500px) {
    .nav-link {
      font-size: 12px !important;
      padding: 8px;
    }
  }

  /* Footer Styles */
  .site-footer {
    margin-top: 6rem;
    padding: 3rem 2rem;
    background: linear-gradient(180deg, var(--bg-primary) 0%, #2a2a2a 100%);
    border-top: 1px solid #444;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-name {
    font-family: "Titillium Web", sans-serif;
    font-size: 1.5rem !important;
    font-weight: 700;
    color: var(--accent) !important;
    margin: 0;
  }

  .footer-tagline {
    font-size: 1rem !important;
    color: var(--text-secondary) !important;
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .footer-link:hover {
    background: var(--accent);
    color: #111111 !important;
    transform: translateY(-3px);
  }

  .footer-copyright {
    font-size: 0.85rem !important;
    color: #888 !important;
    margin: 0;
  }

  @media (max-width: 600px) {
    .site-footer {
      margin-top: 4rem;
      padding: 2rem 1rem;
    }

    .footer-name {
      font-size: 1.25rem !important;
    }
  }
</style>
